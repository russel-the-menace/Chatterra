{
  "name": "chatterra-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "ts-node-dev --respawn --transpile-only server.ts",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc",
    "test:decision": "ts-node --transpile-only response-decision.test.ts",
    "test:language": "ts-node --transpile-only language-policy.test.ts",
    "test:model-gateway": "ts-node --transpile-only model-gateway.test.ts",
    "test:proactive": "ts-node --transpile-only proactive-policy.test.ts",
    "test:proactive-integration": "ts-node --transpile-only proactive-service.integration.test.ts",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:import-json": "ts-node scripts/import-json.ts",
    "db:setup": "npm run db:migrate && npm run db:import-json"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "pg": "^8.22.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}

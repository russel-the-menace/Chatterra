# Usually unnecessary on the same Wi-Fi network: the app derives the Mac host
# from Metro. Set this when the backend uses another host or an HTTPS tunnel.
EXPO_PUBLIC_API_URL=http://192.168.1.50:3000

# Optional until account authentication exists. Set this to the web client's
# chatterra_userId value to share conversations, memories, and relationship state.
EXPO_PUBLIC_USER_ID=

{
  "expo": {
    "name": "Chatterra",
    "slug": "chatterra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chatterra-icon.png",
    "scheme": "chatterra",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chatterra.mobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Chatterra connects to your local development server.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/chatterra-mark.png",
        "monochromeImage": "./assets/images/chatterra-mark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/chatterra-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/chatterra-mark.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Chatterra to select a character avatar.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
